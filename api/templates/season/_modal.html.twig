<div class="modal fade" id="seasonModal" tabindex="-1" aria-labelledby="seasonModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="seasonModalLabel">
                    {{ season.id ? 'Edit Season Id: ' ~ season.id : 'Create Season' }}
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            {{ form_start(form, {
                'action': season.id ? path('season_edit', {'id': season.id}) : path('season_new')
            }) }}
            <div class="modal-body">
                <div class="mb-3">
                    {{ form_row(form.startYear) }}
                </div>
                <div class="mb-3">
                    {{ form_row(form.endYear) }}
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="submit" class="btn btn-primary">Save</button>
            </div>
            {{ form_end(form) }}
        </div>
    </div>
</div>
