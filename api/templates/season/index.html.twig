{% extends 'base.html.twig' %}

{% block title %}Seasons{% endblock %}

{% block body %}
    {% set columnCount = 5 %}
    <div class="container mt-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="mb-0">Seasons</h1>
            <button type="button" class="btn btn-primary" id="newSeasonBtn" data-url="{{ path('season_new') }}">
                Create New
            </button>
        </div>

        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Start Year</th>
                <th>End Year</th>
                <th>Created At</th>
                <th>Modified At</th>
                <th class="text-end">Actions</th>
            </tr>
            </thead>
            <tbody>
            {% for season in seasons %}
                <tr>
                    <td>{{ season.id }}</td>
                    <td>{{ season.startYear }}</td>
                    <td>{{ season.endYear }}</td>
                    <td>{{ season.createdAt|date(DATETIME_FORMAT) }}</td>
                    <td>{{ season.modifiedAt|date(DATETIME_FORMAT) }}</td>
                    <td class="text-end">
                        <button class="btn btn-sm btn-outline-primary edit-btn" data-url="{{ path('season_edit', {'id': season.id}) }}">
                            Edit
                        </button>
                        <button
                            type="button"
                            class="btn btn-sm btn-outline-danger"
                            data-bs-toggle="modal"
                            data-bs-target="#confirmDeleteModal"
                            data-delete-url="{{ path('season_delete', {'id': season.id}) }}"
                            data-item-name="{{ season.id }}"
                            data-token="{{ csrf_token('delete' ~ season.id) }}">
                            Delete
                        </button>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="{{ columnCount }}" class="text-center text-muted">No seasons found.</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>

    {# modal partial #}
    <div id="seasonModalContainer"></div>
{% endblock %}
{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('season/index.js') }}"></script>
{% endblock %}
