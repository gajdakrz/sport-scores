<div class="modal fade" id="memberPositionModal" tabindex="-1" aria-labelledby="memberPositionModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="memberPositionModalLabel">
                    {{ memberPosition.id ? 'Edit Member position Id: ' ~ memberPosition.id : 'Create Member position' }}
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            {{ form_start(form, {
                'action': memberPosition.id ? path('member_position_edit', {'id': memberPosition.id}) : path('member_position_new')
            }) }}
            <div class="modal-body">
                {{ form_widget(form) }}
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="submit" class="btn btn-primary">Save</button>
            </div>
            {{ form_end(form) }}
        </div>
    </div>
</div>
