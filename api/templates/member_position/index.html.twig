{% extends 'base.html.twig' %}

{% block title %}Member Positions{% endblock %}

{% block body %}
    {% set columnCount = 7 %}

    <div class="container mt-5">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="mb-0">Member Positions</h1>
            <button type="button" class="btn btn-primary" id="newMemberPositionBtn" data-url="{{ path('member_position_new') }}">
                Create New
            </button>
        </div>

        <table class="table table-striped table-hover align-middle" id="memberPositionTable">
            <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Created At</th>
                <th>Modified At</th>
                <th class="text-end">Actions</th>
            </tr>
            </thead>
            <tbody>
            {% for memberPosition in memberPositions %}
                <tr>
                    <td>{{ memberPosition.id }}</td>
                    <td>{{ memberPosition.name }}</td>
                    <td>{{ memberPosition.createdAt|date(DATETIME_FORMAT) }}</td>
                    <td>{{ memberPosition.modifiedAt|date(DATETIME_FORMAT) }}</td>
                    <td class="text-end">
                        <button
                            class="btn btn-sm btn-outline-primary edit-btn"
                            data-url="{{ path('member_position_edit', {'id': memberPosition.id}) }}"
                        >
                            Edit
                        </button>
                        <button
                            type="button"
                            class="btn btn-sm btn-outline-danger"
                            data-bs-toggle="modal"
                            data-bs-target="#confirmDeleteModal"
                            data-delete-url="{{ path('member_position_delete', {'id': memberPosition.id}) }}"
                            data-item-name="{{ memberPosition.name }}"
                            data-token="{{ csrf_token('delete' ~ memberPosition.id) }}"
                        >
                            Delete
                        </button>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="{{ columnCount }}" class="text-center text-muted">No memberPositions found.</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>

    {# modal partial #}
    <div id="memberPositionModalContainer"></div>
{% endblock %}
{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('memberPosition') }}
{% endblock %}
