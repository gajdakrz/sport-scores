{% extends 'base.html.twig' %}

{% block title %}Registration Form{% endblock %}

{% block body %}
    <h1 class="mb-4">Formularz rejestracji</h1>

    {{ form_start(registrationForm, {'attr': {'class': 'needs-validation'}}) }}

    <div class="mb-3">
        {{ form_label(registrationForm.email, null, {'label_attr': {'class': 'form-label'}}) }}
        {{ form_widget(registrationForm.email, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(registrationForm.email) }}
    </div>

    <div class="mb-3">
        {{ form_label(registrationForm.plainPassword, null, {'label_attr': {'class': 'form-label'}}) }}
        {{ form_widget(registrationForm.plainPassword, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(registrationForm.plainPassword) }}
    </div>

    <button type="submit" class="btn btn-primary">Register</button>

    {{ form_end(registrationForm) }}
{% endblock %}
