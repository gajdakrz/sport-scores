{% extends 'base.html.twig' %}

{% block title %}Events{% endblock %}

{% block body %}
    {% set columnCount = 7 %}

    <div class="container mt-5">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="mb-0">Events</h1>
            <button type="button" class="btn btn-primary" id="newEventBtn" data-url="{{ path('event_new') }}">
                Create New
            </button>
        </div>
        {# --- FILTER FORM --- #}
        <form method="get" class="row g-3 mb-4">
            <div class="col-md-3">
                <label for="name" class="form-label">Name</label>
                <input
                    type="text"
                    name="name"
                    id="name"
                    class="form-control"
                    value="{{ app.request.get('name') ?: '' }}"
                    placeholder="All">
            </div>
            <div class="col-md-3">
                <label for="competitionId" class="form-label">Competition</label>
                <select name="competitionId" id="competitionId" class="form-select">
                    <option value="">All</option>
                    {% for competition in competitions %}
                        <option value="{{ competition.id }}" {% if competition.id == app.request.get('competitionId') %}selected{% endif %}>
                            {{ competition.name }}
                        </option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-md-2 align-self-end">
                <button type="submit" class="btn btn-secondary w-100">Filter</button>
            </div>
        </form>
        {# --- END FILTER FORM --- #}
        <table class="table table-striped table-hover align-middle" id="eventTable">
            <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Competition</th>
                <th>Created At</th>
                <th>Modified At</th>
                <th class="text-end">Actions</th>
            </tr>
            </thead>
            <tbody>
            {% for event in events %}
                <tr>
                    <td>{{ event.id }}</td>
                    <td>{{ event.name }}</td>
                    <td>{{ event.competition.name ?? '' }}</td>
                    <td>{{ event.createdAt|date(DATETIME_FORMAT) }}</td>
                    <td>{{ event.modifiedAt|date(DATETIME_FORMAT) }}</td>
                    <td class="text-end">
                        <button class="btn btn-sm btn-outline-primary edit-btn" data-url="{{ path('event_edit', {'id': event.id}) }}">
                            Edit
                        </button>
                        <button
                            type="button"
                            class="btn btn-sm btn-outline-danger"
                            data-bs-toggle="modal"
                            data-bs-target="#confirmDeleteModal"
                            data-delete-url="{{ path('event_delete', {'id': event.id}) }}"
                            data-item-name="{{ event.name }}"
                            data-token="{{ csrf_token('delete' ~ event.id) }}">
                            Delete
                        </button>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="{{ columnCount }}" class="text-center text-muted">No events found.</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
        {% include '_pagination.html.twig' with {
            pagination: pagination,
            route: app.request.attributes.get('_route'),
            routeParams: app.request.attributes.get('_route_params'),
            query: app.request.query.all,
            label: 'Events pagination'
        } %}
    </div>

    {# modal partial #}
    <div id="eventModalContainer"></div>
{% endblock %}
{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('event/index.js') }}"></script>
{% endblock %}
