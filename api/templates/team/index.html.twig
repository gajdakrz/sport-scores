{% extends 'base.html.twig' %}

{% block title %}Teams{% endblock %}

{% block body %}
    {% set columnCount = 7 %}

    <div class="container mt-5">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="mb-0">Teams</h1>
            <button type="button" class="btn btn-primary" id="newTeamBtn" data-url="{{ path('team_new') }}">
                Create New
            </button>
        </div>
        {# --- FILTER FORM --- #}
        <form method="get" class="row g-3 mb-4">
            <div class="col-md-3">
                <label for="name" class="form-label">Name</label>
                <input
                    type="text"
                    name="name"
                    id="name"
                    class="form-control"
                    value="{{ app.request.get('name') ?: '' }}"
                    placeholder="All">
            </div>
            <div class="col-md-3">
                <label for="countryId" class="form-label">Country</label>
                <select name="countryId" id="countryId" class="form-select">
                    <option value="">All</option>
                    {% for country in countries %}
                        <option value="{{ country.id }}" {% if country.id == app.request.get('countryId') %}selected{% endif %}>
                            {{ country.name }}
                        </option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-md-3">
                <label for="teamType" class="form-label">Team Type</label>
                <select name="teamType" id="teamType" class="form-select">
                    <option value="">All</option>
                    {% for type in teamTypes %}
                        <option value="{{ type.value }}" {% if type.value == app.request.get('teamType') %}selected{% endif %}>
                            {{ type.label() ?: type.name|capitalize }}
                        </option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-md-2 align-self-end">
                <button type="submit" class="btn btn-secondary w-100">Filter</button>
            </div>
        </form>
        {# --- END FILTER FORM --- #}
        <table id="teamTable" class="table table-striped table-hover align-middle">
            <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Country</th>
                <th>Type</th>
                <th>Created At</th>
                <th>Modified At</th>
                <th class="text-end">Actions</th>
            </tr>
            </thead>
            <tbody>
            {% for team in teams %}
                <tr>
                    <td>{{ team.id }}</td>
                    <td>{{ team.name }}</td>
                    <td>{{ team.country.name ?? '' }}</td>
                    <td>{{ team.teamType.name|replace({'_': ' '})|capitalize }}</td>
                    <td>{{ team.createdAt|date(DATETIME_FORMAT) }}</td>
                    <td>{{ team.modifiedAt|date(DATETIME_FORMAT) }}</td>
                    <td class="text-end">
                        <button class="btn btn-sm btn-outline-primary edit-btn" data-url="{{ path('team_edit', {'id': team.id}) }}">
                            Edit
                        </button>
                        <button
                            type="button"
                            class="btn btn-sm btn-outline-danger"
                            data-bs-toggle="modal"
                            data-bs-target="#confirmDeleteModal"
                            data-delete-url="{{ path('team_delete', {'id': team.id}) }}"
                            data-item-name="{{ team.name }}"
                            data-token="{{ csrf_token('delete' ~ team.id) }}">
                            Delete
                        </button>
                        <a
                            href="{{ path('team_game_result_season_stats', { id: team.id }) }}"
                            class="btn btn-sm btn-outline-info"
                            target="_blank"
                            rel="noopener"
                        >
                            Results
                        </a>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="{{ columnCount }}" class="text-center text-muted">No teams found.</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
        <nav aria-label="Page navigation">
            <ul class="pagination justify-content-center">
                {% set queryParams = app.request.query.all|filter((v, k) => k != 'page') %}
                {{ pagerfanta(teams, null, {
                    'routeName': app.request.attributes.get('_route'),
                    'routeParams': app.request.attributes.get('_route_params')|merge(queryParams)
                }) }}
            </ul>
        </nav>
    </div>

    {# modal partial #}
    <div id="teamModalContainer"></div>
{% endblock %}
{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('team') }}
{% endblock %}
