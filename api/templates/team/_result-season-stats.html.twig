{% set childColumnCount = 11 %}
<table class="table table-striped table-hover align-middle" id="gameResultTable">
    <thead>
    <tr>
        <th>Season Id</th>
        <th>Season Name</th>
        <th>Competition</th>
        <th>Matches</th>
        <th>Wins</th>
        <th>Losses</th>
        <th>Draws</th>
        <th>Unknowns</th>
        <th>Win Rate</th>
        <th>Actions</th>
    </tr>
    </thead>
    <tbody>
    {% for resultSeasonStat in resultSeasonStats %}
        <tr>
            <td>{{ resultSeasonStat.season.id ?? '' }}</td>
            <td>{{ resultSeasonStat.season.mergedStartEndYear ?? '' }}</td>
            <td>{{ resultSeasonStat.competition.name ?? '' }}</td>
            <td>{{ resultSeasonStat.stats.total ?? '' }}</td>
            <td>{{ resultSeasonStat.stats.wins ?? '' }}</td>
            <td>{{ resultSeasonStat.stats.losses ?? '' }}</td>
            <td>{{ resultSeasonStat.stats.draws ?? '' }}</td>
            <td>{{ resultSeasonStat.stats.unknowns ?? '' }}</td>
            <td>{{ resultSeasonStat.stats.winRate ?? '' }}</td>
            <td>
                <button
                    class="btn btn-sm btn-outline-info season-details"
                    data-team-id="{{ resultSeasonStat.team.id }}"
                    data-season-id="{{ resultSeasonStat.season.id }}"
                    data-competition-id="{{ resultSeasonStat.competition.id }}"
                >
                    Details
                </button>
            </td>
        </tr>
    {% else %}
        <tr>
            <td colspan="{{ childColumnCount }}" class="text-center text-muted">
                No game results found.
            </td>
        </tr>
    {% endfor %}
    </tbody>
</table>
