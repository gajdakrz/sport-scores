{% extends 'base.html.twig' %}

{% block title %}Game results for Team{% endblock %}

{% block body %}
    {% set childColumnCount = 11 %}
    <div class="container mt-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="mb-0">Game results for Team: {{ team.name ?? '' }}</h1>
        </div>
        {# --- FILTER FORM --- #}
        <form method="get" class="row g-3 mb-4">
            <div class="col-md-3">
                <label for="seasonId" class="form-label">Season</label>
                <select name="seasonId" id="seasonId" class="form-select">
                    <option value="">All</option>
                    {% for season in seasons %}
                        <option value="{{ season.id }}" {% if season.id == app.request.get('seasonId') %}selected{% endif %}>
                            {{ season.mergedStartEndYear }}
                        </option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-md-3">
                <label for="competitionId" class="form-label">Competition</label>
                <select name="competitionId" id="competitionId" class="form-select">
                    <option value="">All</option>
                    {% for competition in competitions %}
                        <option value="{{ competition.id }}" {% if competition.id == app.request.get('competitionId') %}selected{% endif %}>
                            {{ competition.name }}
                        </option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-md-2 align-self-end">
                <button type="submit" class="btn btn-secondary w-100">Filter</button>
            </div>
        </form>
        {# --- END FILTER FORM --- #}
        <table class="table table-striped table-hover align-middle" id="gameResultTable">
            <thead>
            <tr>
                <th>Season Name</th>
                <th>Competition</th>
                <th>Matches</th>
                <th>Wins</th>
                <th>Losses</th>
                <th>Draws</th>
                <th>Unknowns</th>
                <th>Win Rate</th>
                <th>Actions</th>
            </tr>
            </thead>
            <tbody>
            {% for resultSeasonStat in resultSeasonStats %}
                <tr>
                    <td>{{ resultSeasonStat.season.mergedStartEndYear ?? '' }}</td>
                    <td>{{ resultSeasonStat.competition.name ?? '' }}</td>
                    <td>{{ resultSeasonStat.total ?? '' }}</td>
                    <td>{{ resultSeasonStat.wins ?? '' }}</td>
                    <td>{{ resultSeasonStat.losses ?? '' }}</td>
                    <td>{{ resultSeasonStat.draws ?? '' }}</td>
                    <td>{{ resultSeasonStat.unknowns ?? '' }}</td>
                    <td>{{ resultSeasonStat.winRate ?? '' }}</td>
                    <td>
                        <button
                            class="btn btn-sm btn-outline-info season-details"
                            data-team-id="{{ team.id }}"
                            data-season-id="{{ resultSeasonStat.season.id }}"
                            data-competition-id="{{ resultSeasonStat.competition.id }}"
                        >
                            Details
                        </button>
                        {% if resultSeasonStat.competition.isBracket %}
                            <a
                                href="{{ path('build_bracket',
                                    {
                                        competition: resultSeasonStat.competition.id,
                                        season: resultSeasonStat.season.id,
                                        team: team.id,
                                    })
                                }}"
                                class="btn btn-sm btn-outline-info"
                                target="_blank"
                                rel="noopener"
                            >
                                Results
                            </a>
                        {% endif %}
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="{{ childColumnCount }}" class="text-center text-muted">
                        No game results found.
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
        {{ pagerfanta(resultSeasonStats, null, {
            'routeName': app.request.attributes.get('_route'),
            'routeParams': app.request.attributes.get('_route_params'),
            'queryParams': app.request.query.all
        }) }}
    </div>
    {# modal partial #}
    <div id="teamSeasonDetailsModalContainer"></div>
{% endblock %}
{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('team/result-season-stats.js') }}"></script>
{% endblock %}
