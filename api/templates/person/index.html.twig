{% extends 'base.html.twig' %}

{% block title %}Persons{% endblock %}

{% block body %}
    {% set columnCount = 9 %}

    <div class="container mt-5">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="mb-0">Persons</h1>
            <button type="button" class="btn btn-primary" id="newPersonBtn" data-url="{{ path('person_new') }}">
                Create New
            </button>
        </div>

        <table class="table table-striped table-hover align-middle" id="personTable">
            <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>First Name</th>
                <th>Last Name</th>
                <th>Gender</th>
                <th>Birth Date</th>
                <th>Origin Country</th>
                <th>Created At</th>
                <th>Modified At</th>
                <th class="text-end">Actions</th>
            </tr>
            </thead>
            <tbody>
            {% for person in persons %}
                <tr>
                    <td>{{ person.id }}</td>
                    <td>{{ person.firstName }}</td>
                    <td>{{ person.lastName }}</td>
                    <td>{{ person.gender.value|capitalize }}</td>
                    <td>{{ person.birthDate|date(DATE_FORMAT) }}</td>
                    <td>{{ person.originCountry.name }}</td>
                    <td>{{ person.createdAt|date(DATETIME_FORMAT) }}</td>
                    <td>{{ person.modifiedAt|date(DATETIME_FORMAT) }}</td>
                    <td class="text-end">
                        <button
                            class="btn btn-sm btn-outline-primary edit-btn"
                            data-url="{{ path('person_edit', {'id': person.id}) }}"
                        >
                            Edit
                        </button>
                        <button
                            type="button"
                            class="btn btn-sm btn-outline-danger"
                            data-bs-toggle="modal"
                            data-bs-target="#confirmDeleteModal"
                            data-delete-url="{{ path('person_delete', {'id': person.id}) }}"
                            data-item-name="{{ person.firstName ~ ' ' ~ person.lastName }}"
                            data-token="{{ csrf_token('delete' ~ person.id) }}"
                        >
                            Delete
                        </button>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="{{ columnCount }}" class="text-center text-muted">No persons found.</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>

    {# modal partial #}
    <div id="personModalContainer"></div>
{% endblock %}
{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('person') }}
{% endblock %}
