{% extends 'base.html.twig' %}

{% block title %}Games{% endblock %}

{% block body %}
    {% set columnCount = 6 %}

    <div class="container mt-5">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="mb-0">Games</h1>
            <button type="button" class="btn btn-primary" id="newGameBtn" data-url="{{ path('game_new') }}">
                Create New
            </button>
        </div>

        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Event</th>
                <th>Created At</th>
                <th>Modified At</th>
                <th class="text-end">Actions</th>
            </tr>
            </thead>
            <tbody>
            {% for game in games %}
                <tr>
                    <td>{{ game.id }}</td>
                    <td>{{ game.name }}</td>
                    <td>{{ game.event ? game.event.name : '' }}</td>
                    <td>{{ game.createdAt|date(DATETIME_FORMAT) }}</td>
                    <td>{{ game.modifiedAt|date(DATETIME_FORMAT) }}</td>
                    <td class="text-end">
                        <button class="btn btn-sm btn-outline-primary edit-btn" data-url="{{ path('game_edit', {'id': game.id}) }}">
                            Edit
                        </button>
                        <button
                            type="button"
                            class="btn btn-sm btn-outline-danger"
                            data-bs-toggle="modal"
                            data-bs-target="#confirmDeleteModal"
                            data-delete-url="{{ path('game_delete', {'id': game.id}) }}"
                            data-item-name="{{ game.name }}"
                            data-token="{{ csrf_token('delete' ~ game.id) }}">
                            Delete
                        </button>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="{{ columnCount }}" class="text-center text-muted">No games found.</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>

    {# modal partial #}
    <div id="gameModalContainer"></div>
{% endblock %}
{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('game/index.js') }}"></script>
{% endblock %}
