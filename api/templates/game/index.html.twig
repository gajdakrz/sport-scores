{% extends 'base.html.twig' %}

{% block title %}Games{% endblock %}

{% block body %}
    {% set columnCount = 8 %}

    <div class="container mt-5">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="mb-0">Games</h1>
            <button type="button" class="btn btn-primary" id="newGameBtn" data-url="{{ path('game_new') }}">
                Create New
            </button>
        </div>
        {# --- FILTER FORM --- #}
        <form method="get" class="row g-3 mb-4">
            <div class="col-md-3">
                <label for="seasonId" class="form-label">Season</label>
                <select name="seasonId" id="seasonId" class="form-select">
                    <option value="">All</option>
                    {% for season in seasons %}
                        <option value="{{ season.id }}" {% if season.id == app.request.get('seasonId') %}selected{% endif %}>
                            {{ season.mergedStartEndYear }}
                        </option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-md-3">
                <label for="competitionId" class="form-label">Competition</label>
                <select name="competitionId" id="competitionId" class="form-select">
                    <option value="">All</option>
                    {% for competition in competitions %}
                        <option value="{{ competition.id }}" {% if competition.id == app.request.get('competitionId') %}selected{% endif %}>
                            {{ competition.name }}
                        </option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-md-3">
                <label for="eventId" class="form-label">Event</label>
                <select name="eventId" id="eventId" class="form-select">
                    <option value="">All</option>
                    {% for event in events %}
                        <option value="{{ event.id }}" {% if event.id == app.request.get('eventId') %}selected{% endif %}>
                            {{ event.name }}
                        </option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-md-3">
                <label for="date" class="form-label">Date</label>
                <input
                    type="text"
                    name="date"
                    id="date"
                    class="form-control flatpickr"
                    value="{{ app.request.get('date') ?: '' }}"
                    placeholder="All">
            </div>
            <div class="col-md-2 align-self-end">
                <button type="submit" class="btn btn-secondary w-100">Filter</button>
            </div>
        </form>
        {# --- END FILTER FORM --- #}
        <table class="table table-striped table-hover align-middle" id="gameTable">
            <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Date</th>
                <th>Sport</th>
                <th>Season</th>
                <th>Competition</th>
                <th>Event</th>
                <th>Created At</th>
                <th>Modified At</th>
                <th class="text-end">Actions</th>
            </tr>
            </thead>
            <tbody>
            {% for game in games %}
                <tr>
                    <td>{{ game.id }}</td>
                    <td>{{ game.date|date(DATE_FORMAT) }}</td>
                    <td>{{ game.event.competition.sport.name ?? '' }}</td>
                    <td>{{ game.season.mergedStartEndYear ?? '' }}</td>
                    <td>{{ game.event.competition.name ?? '' }}</td>
                    <td>{{ game.event.name ?? '' }}</td>
                    <td>{{ game.createdAt|date(DATETIME_FORMAT) }}</td>
                    <td>{{ game.modifiedAt|date(DATETIME_FORMAT) }}</td>
                    <td class="text-end">
                        <button class="btn btn-sm btn-outline-primary edit-btn" data-url="{{ path('game_edit', {'id': game.id}) }}">
                            Edit
                        </button>
                        <button
                            type="button"
                            class="btn btn-sm btn-outline-danger"
                            data-bs-toggle="modal"
                            data-bs-target="#confirmDeleteModal"
                            data-delete-url="{{ path('game_delete', {'id': game.id}) }}"
                            data-item-name="{{ game.id }}"
                            data-token="{{ csrf_token('delete' ~ game.id) }}">
                            Delete
                        </button>
                        <button class="btn btn-sm btn-outline-info expand-results" data-id="{{ game.id }}">
                            Results
                        </button>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="{{ columnCount }}" class="text-center text-muted">No games found.</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
        {% include '_pagination.html.twig' with {
            pagination: pagination,
            route: app.request.attributes.get('_route'),
            query: app.request.query.all,
            label: 'Games pagination'
        } %}
    </div>

    {# modal partial #}
    <div id="gameModalContainer"></div>
{% endblock %}
{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('game/index.js') }}"></script>
{% endblock %}
