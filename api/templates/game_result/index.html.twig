{% extends 'base.html.twig' %}

{% block title %}Game results{% endblock %}

{% block body %}
    {% set columnCount = 9 %}

    <div class="container mt-5">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="mb-0">Game results</h1>
            <button type="button" class="btn btn-primary" id="newGameResultBtn" data-url="{{ path('game_result_new') }}">
                Create New
            </button>
        </div>
        {# --- FILTER FORM --- #}
        <form method="get" class="row g-3 mb-4">
            <div class="col-md-3">
                <label for="date" class="form-label">Game Date</label>
                <input
                    type="text"
                    name="date"
                    id="date"
                    class="form-control flatpickr"
                    value="{{ app.request.get('date') ?: '' }}"
                    placeholder="All">
            </div>
            <div class="col-md-3">
                <label for="teamId" class="form-label">Team</label>
                <select name="teamId" id="teamId" class="form-select">
                    <option value="">All</option>
                    {% for team in teams %}
                        <option value="{{ team.id }}" {% if team.id == app.request.get('teamId') %}selected{% endif %}>
                            {{ team.name }}
                        </option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-md-3">
                <label for="matchStatus" class="form-label">Match status</label>
                <select name="matchResultStatus" id="matchStatus" class="form-select">
                    <option value="">All</option>
                    {% for status in matchResultStatuses %}
                        <option value="{{ status }}" {% if status == app.request.get('matchResultStatus') %}selected{% endif %}>
                            {{ status|capitalize }}
                        </option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-md-2 align-self-end">
                <button type="submit" class="btn btn-secondary w-100">Filter</button>
            </div>
        </form>
        {# --- END FILTER FORM --- #}
        <table class="table table-striped table-hover align-middle" id="gameResultTable">
            <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Game Id</th>
                <th>Game Date</th>
                <th>Team</th>
                <th>Match score</th>
                <th>Ranking score</th>
                <th>Match status</th>
                <th>Created At</th>
                <th>Modified At</th>
                <th class="text-end">Actions</th>
            </tr>
            </thead>
            <tbody>
            {% for gameResult in gameResults %}
                <tr>
                    <td>{{ gameResult.id }}</td>
                    <td>{{ gameResult.game.id ?? '' }}</td>
                    <td>{{ gameResult.game.date|date(DATE_FORMAT) }}</td>
                    <td>{{ gameResult.team.name ?? '' }}</td>
                    <td>{{ gameResult.matchScore }}</td>
                    <td>{{ gameResult.rankingScore }}</td>
                    <td>{{ gameResult.matchResult.value ?? '' }}</td>
                    <td>{{ gameResult.createdAt|date(DATETIME_FORMAT) }}</td>
                    <td>{{ gameResult.modifiedAt|date(DATETIME_FORMAT) }}</td>
                    <td class="text-end">
                        <button class="btn btn-sm btn-outline-primary edit-btn" data-url="{{ path('game_result_edit', {'id': gameResult.id}) }}">
                            Edit
                        </button>
                        <button
                            type="button"
                            class="btn btn-sm btn-outline-danger"
                            data-bs-toggle="modal"
                            data-bs-target="#confirmDeleteModal"
                            data-delete-url="{{ path('game_result_delete', {'id': gameResult.id}) }}"
                            data-item-name="{{ gameResult.id }}"
                            data-token="{{ csrf_token('delete' ~ gameResult.id) }}">
                            Delete
                        </button>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="{{ columnCount }}" class="text-center text-muted">No game results found.</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
        <nav aria-label="Page navigation">
            <ul class="pagination justify-content-center">
                {{ pagerfanta(gameResults, null, {
                    'routeName': app.request.attributes.get('_route'),
                    'routeParams': app.request.attributes.get('_route_params'),
                    'queryParams': app.request.query.all
                }) }}
            </ul>
        </nav>
    </div>

    {# modal partial #}
    <div id="gameResultModalContainer"></div>
{% endblock %}
{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('gameResult') }}
{% endblock %}
