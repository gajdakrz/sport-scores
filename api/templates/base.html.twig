<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8">
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <title>{% block title %}Sport Scores witamy!{% endblock %}</title>

    {# Bootstrap 5 z CDN #}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

    {# Flatpickr CSS #}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">

    {# Your custom CSS #}
    {% block stylesheets %}
        {{ encore_entry_link_tags('app') }}
    {% endblock %}
</head>
<body class="bg-light" data-page="{{ app.request.attributes.get('_route') }}">
    <nav class="navbar navbar-dark bg-dark fixed-top">
        <div class="container-fluid">
            <div class="d-flex align-items-center gap-3">
                <a class="navbar-brand mb-0" href="#">SportScore</a>
                {# === SPORT SWITCHER (LEFT) === #}
                <select id="sport-switcher"
                        class="form-select form-select-sm text-bg-dark"
                        style="width: 160px;">
                    {% if currentSport.getSport() %}
                        <option value="{{ currentSport.getSport().id }}" selected>
                            {{ currentSport.getSport().name }}
                        </option>
                    {% else %}
                        <option value="" selected>Select sport</option>
                    {% endif %}
                    {% for sport in sports %}
                        {% if not currentSport.getSport() or sport.id != currentSport.getSport().id %}
                            <option value="{{ sport.id }}">{{ sport.name }}</option>
                        {% endif %}
                    {% endfor %}
                </select>
            </div>
            <button class="navbar-toggler" type="button" data-bs-toggle="offcanvas" data-bs-target="#offcanvasDarkNavbar" aria-controls="offcanvasDarkNavbar" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="offcanvas offcanvas-end text-bg-dark" tabindex="-1" id="offcanvasDarkNavbar" aria-labelledby="offcanvasDarkNavbarLabel">
                <div class="offcanvas-header">
                    <h5 class="offcanvas-title" id="offcanvasDarkNavbarLabel">SportScore</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" aria-label="Close"></button>
                </div>
                <div class="offcanvas-body">
                    <ul class="navbar-nav justify-content-end flex-grow-1 pe-3">
                        <li class="nav-item">
                            <a class="nav-link active" aria-current="page" href="{{ path('app_home') }}">Home</a>
                        </li>
                        <li class="nav-item dropdown">
                            <button
                                class="nav-link dropdown-toggle"
                                type="button"
                                data-bs-toggle="dropdown"
                                aria-expanded="false"
                            >
                                Services
                            </button>
                            <ul class="dropdown-menu dropdown-menu-dark">
                                <li><a class="dropdown-item" href="{{ path('sport_index') }}">Sports</a></li>
                                <li><a class="dropdown-item" href="{{ path('competition_index') }}">Competitions</a></li>
                                <li><a class="dropdown-item" href="{{ path('event_index') }}">Events</a></li>
                                <li><a class="dropdown-item" href="{{ path('game_index') }}">Games</a></li>
                                <li><a class="dropdown-item" href="{{ path('game_result_index') }}">Games Results</a></li>
                                <li><a class="dropdown-item" href="{{ path('country_index') }}">Countries</a></li>
                                <li><a class="dropdown-item" href="{{ path('team_index') }}">Teams</a></li>
                                <li><a class="dropdown-item" href="{{ path('season_index') }}">Seasons</a></li>
                            </ul>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </nav>
    <div class="container py-5">
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ label }} alert-dismissible fade show" role="alert">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}
        {% endfor %}
        {% block body %}{% endblock %}
    </div>
    {% include '_modal_confirm.html.twig' %}
    {% block javascripts %}
        {{ encore_entry_script_tags('app') }}
        {# Boostrap JS #}
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
        {# Flatpickr JS #}
        <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
        <script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/pl.js"></script>
    {% endblock %}
</body>
</html>

