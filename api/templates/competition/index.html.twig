{% extends 'base.html.twig' %}

{% block title %}Competitions{% endblock %}

{% block body %}
    {% set columnCount = 7 %}

    <div class="container mt-5">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="mb-0">Competitions</h1>
            <button type="button" class="btn btn-primary" id="newCompetitionBtn" data-url="{{ path('competition_new') }}">
                Create New
            </button>
        </div>

        <table class="table table-striped table-hover align-middle" id="competitonTable">
            <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Gender</th>
                <th>Is Bracket</th>
                <th>Created At</th>
                <th>Modified At</th>
                <th class="text-end">Actions</th>
            </tr>
            </thead>
            <tbody>
            {% for competition in competitions %}
                <tr>
                    <td>{{ competition.id }}</td>
                    <td>{{ competition.name }}</td>
                    <td>{{ competition.gender.value|capitalize }}</td>
                    <td>
                        <div class="form-check form-switch">
                            <input type="checkbox" class="form-check-input"
                                   aria-label="Is bracket"
                                {{ competition.isBracket ? 'checked' : '' }}
                                   disabled>
                        </div>
                    </td>
                    <td>{{ competition.createdAt|date(DATETIME_FORMAT) }}</td>
                    <td>{{ competition.modifiedAt|date(DATETIME_FORMAT) }}</td>
                    <td class="text-end">
                        <button class="btn btn-sm btn-outline-primary edit-btn" data-url="{{ path('competition_edit', {'id': competition.id}) }}">
                            Edit
                        </button>
                        <button
                            type="button"
                            class="btn btn-sm btn-outline-danger"
                            data-bs-toggle="modal"
                            data-bs-target="#confirmDeleteModal"
                            data-delete-url="{{ path('competition_delete', {'id': competition.id}) }}"
                            data-item-name="{{ competition.name }}"
                            data-token="{{ csrf_token('delete' ~ competition.id) }}">
                            Delete
                        </button>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="{{ columnCount }}" class="text-center text-muted">No competitions found.</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>

    {# modal partial #}
    <div id="competitionModalContainer"></div>
{% endblock %}
{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('competition') }}
{% endblock %}
